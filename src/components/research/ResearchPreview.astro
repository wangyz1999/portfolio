---
import { Image } from "astro:assets";
import Icon from "../Icon.astro";

const { research, as: Element = "div" } = Astro.props;

const getIcon = (key: string) => {
  const lowerKey = key.toLowerCase();
  if (lowerKey.includes("arxiv")) return "arxiv";
  if (lowerKey.includes("code") || lowerKey.includes("github")) return "github";
  if (lowerKey.includes("pdf")) return "pdf";
  if (lowerKey.includes("paper") || lowerKey.includes("publication"))
    return "paper";
  if (lowerKey.includes("video") || lowerKey.includes("demo")) return "video";
  if (lowerKey.includes("website") || lowerKey.includes("site"))
    return "website";
  if (lowerKey.includes("overview") || lowerKey.includes("project"))
    return "link";
  if (lowerKey.includes("slides")) return "slides";
  if (lowerKey.includes("poster")) return "poster";
  if (lowerKey.includes("dataset") || lowerKey.includes("huggingface"))
    return "dataset";
  return "link";
};

const getIconTitle = (key: string) => {
  const lowerKey = key.toLowerCase();
  if (lowerKey.includes("arxiv")) return "arXiv";
  if (lowerKey.includes("code") || lowerKey.includes("github")) return "Code";
  if (lowerKey.includes("pdf")) return "PDF";
  if (lowerKey.includes("paper") || lowerKey.includes("publication"))
    return "Paper";
  if (lowerKey.includes("video") || lowerKey.includes("demo")) return "Video";
  if (lowerKey.includes("website") || lowerKey.includes("site"))
    return "Website";
  if (lowerKey.includes("overview") || lowerKey.includes("project"))
    return "Project";
  if (lowerKey.includes("slides")) return "Slides";
  if (lowerKey.includes("poster")) return "Poster";
  if (lowerKey.includes("dataset") || lowerKey.includes("huggingface"))
    return "Dataset";
  return key;
};

const paperLink =
  (Object.entries(research.data.links).find(
    ([key]) =>
      key.toLowerCase().includes("paper") ||
      key.toLowerCase().includes("publication"),
  )?.[1] as string) || `/research/${research.id}`;

const categoryConfig: Record<string, { label: string; style: string }> = {
  preprint: {
    label: "Preprint",
    style:
      "bg-rose-100/80 text-rose-600/90 dark:bg-rose-500/10 dark:text-rose-400/80",
  },
  conference: {
    label: "Conference",
    style:
      "bg-indigo-100/80 text-indigo-600/90 dark:bg-indigo-500/10 dark:text-indigo-400/80",
  },
  journal: {
    label: "Journal",
    style:
      "bg-teal-100/80 text-teal-700/90 dark:bg-teal-500/10 dark:text-teal-400/80",
  },
  workshop: {
    label: "Workshop",
    style:
      "bg-orange-100/80 text-orange-600/90 dark:bg-orange-500/10 dark:text-orange-400/80",
  },
};

const category = research.data.category;
const catCfg = category ? categoryConfig[category] : null;
const year = new Date(research.data.publishDate).getFullYear();
const venue = research.data.venue;
const tldr = research.data.tldr;
---

<Element
  class="group flex flex-col gap-0 overflow-hidden rounded-xl border border-textColor/10 bg-bgColor shadow-sm dark:border-white/10"
>
  <div class="flex flex-col gap-4 p-5 sm:flex-row">
    <!-- Thumbnail -->
    <div class="shrink-0 self-center">
      <button
        type="button"
        class="img-preview-btn block overflow-hidden rounded-lg cursor-zoom-in"
        data-src={typeof research.data.feature === "string"
          ? research.data.feature
          : research.data.feature.src}
        data-alt={research.data.title}
      >
        <Image
          src={research.data.feature}
          alt={research.data.title}
          height={200}
          width={220}
          class="object-cover transition-transform duration-300 group-hover:scale-105"
        />
      </button>
    </div>

    <!-- Body -->
    <div class="flex min-w-0 flex-1 flex-col gap-2.5">
      <!-- Line 1: Title -->
      <div class="flex flex-col gap-1">
        <a
          href={paperLink}
          target={paperLink.startsWith("/") ? "_self" : "_blank"}
          rel={paperLink.startsWith("/") ? "" : "noopener noreferrer"}
        >
          <h2
            class="text-lg font-bold leading-snug text-textColor transition-colors hover:text-accent dark:hover:text-accent"
          >
            {research.data.title}
          </h2>
        </a>

        <!-- Category badge · Venue · Year -->
        <div class="flex flex-wrap items-center gap-2">
          {
            catCfg && (
              <span
                class={`rounded-sm px-1.5 py-0.5 text-xs font-semibold uppercase tracking-wider ${catCfg.style}`}
              >
                {catCfg.label}
              </span>
            )
          }
          <span class="text-xs text-textColor/40 dark:text-white/30">
            {
              venue ? (
                <>
                  <span class="font-mono font-semibold text-accent dark:text-accent">
                    {venue}
                  </span>
                  <span class="opacity-40">·</span>
                </>
              ) : null
            }
            {year}
          </span>
        </div>
      </div>

      <!-- Line 2: Topic tags -->
      {
        research.data.tags && research.data.tags.length > 0 && (
          <div class="flex flex-wrap gap-1">
            {research.data.tags.map((tag: string) => (
              <span class="rounded-full bg-zinc-200/80 px-2.5 py-0.5 text-xs font-medium text-zinc-400 dark:bg-zinc-800 dark:text-zinc-500">
                {tag}
              </span>
            ))}
          </div>
        )
      }

      <!-- Line 3: Authors -->
      <div
        class="flex flex-wrap gap-x-1 text-sm text-textColor/60 dark:text-white/50"
      >
        {
          research.data.authors.map((author: string, idx: number) => (
            <span>
              <span
                class={
                  idx === research.data.author_idx
                    ? "font-semibold text-textColor dark:text-white"
                    : ""
                }
              >
                {author}
                {idx !== research.data.authors.length - 1 ? "," : ""}
              </span>
            </span>
          ))
        }
      </div>

      <!-- TL;DR -->
      {
        tldr && (
          <p class="border-l-2 border-accent/40 pl-2.5 text-sm leading-relaxed text-textColor/60 dark:border-accent/40 dark:text-white/50">
            <span class="font-semibold text-textColor/80 dark:text-white/70">
              TL;DR
            </span>{" "}
            — {tldr}
          </p>
        )
      }

      <!-- Line 5: Links -->
      <div class="flex flex-wrap gap-1.5 pt-0.5">
        {
          Object.entries(research.data.links).map(([key, value]) => {
            const iconType = getIcon(key);
            const iconTitle = getIconTitle(key);
            const url = value as string;
            return (
              <a
                href={url}
                target={url.startsWith("/") ? "_self" : "_blank"}
                rel={url.startsWith("/") ? "" : "noopener noreferrer"}
                class="flex items-center gap-1 rounded-sm border border-textColor/15 bg-textColor/5 px-2 py-1 text-sm font-medium text-textColor/70 transition-all hover:border-accent hover:bg-accent hover:text-white dark:border-white/15 dark:bg-white/5 dark:text-white/60 dark:hover:border-accent dark:hover:bg-accent dark:hover:text-white"
                title={iconTitle}
              >
                <Icon name={iconType} class="h-3.5 w-3.5" />
                <span>{iconTitle}</span>
              </a>
            );
          })
        }
      </div>
    </div>
  </div>
</Element>

<script>
  // Create a single global lightbox on first use
  function getOrCreateLightbox() {
    let lb = document.getElementById("global-img-lightbox");
    if (lb) return lb;

    lb = document.createElement("div");
    lb.id = "global-img-lightbox";
    lb.style.cssText = [
      "display:none",
      "position:fixed",
      "inset:0",
      "z-index:9999",
      "background:rgba(0,0,0,0.75)",
      "backdrop-filter:blur(4px)",
      "align-items:center",
      "justify-content:center",
      "padding:1rem",
    ].join(";");

    lb.innerHTML = `
			<div style="position:relative;max-width:56rem;width:100%">
				<img id="lightbox-img" style="width:100%;border-radius:0.75rem;box-shadow:0 25px 50px rgba(0,0,0,0.5);object-fit:contain;max-height:80vh" src="" alt="" />
				<button id="lightbox-close" style="position:absolute;top:-0.75rem;right:-0.75rem;display:flex;align-items:center;justify-content:center;width:2rem;height:2rem;border-radius:9999px;background:rgba(255,255,255,0.95);color:#1f2937;border:none;cursor:pointer;box-shadow:0 2px 8px rgba(0,0,0,0.3)">
					<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
				</button>
			</div>`;

    document.body.appendChild(lb);

    const close = () => {
      lb!.style.display = "none";
      document.body.style.overflow = "";
    };
    document.getElementById("lightbox-close")!.addEventListener("click", close);
    lb.addEventListener("click", (e) => {
      if (e.target === lb) close();
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") close();
    });

    return lb;
  }

  document
    .querySelectorAll<HTMLButtonElement>(".img-preview-btn")
    .forEach((btn) => {
      btn.addEventListener("click", () => {
        const lb = getOrCreateLightbox();
        const img = document.getElementById("lightbox-img") as HTMLImageElement;
        img.src = btn.dataset.src ?? "";
        img.alt = btn.dataset.alt ?? "";
        lb.style.display = "flex";
        document.body.style.overflow = "hidden";
      });
    });
</script>
