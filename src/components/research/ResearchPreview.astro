---
import { Image } from "astro:assets";
import Icon from "../Icon.astro";

const { research, as: Element = "div" } = Astro.props;

const getIcon = (key: string) => {
	const lowerKey = key.toLowerCase();
	if (lowerKey.includes("arxiv")) return "arxiv";
	if (lowerKey.includes("code") || lowerKey.includes("github")) return "github";
	if (lowerKey.includes("pdf")) return "pdf";
	if (lowerKey.includes("paper") || lowerKey.includes("publication")) return "paper";
	if (lowerKey.includes("video") || lowerKey.includes("demo")) return "video";
	if (lowerKey.includes("website") || lowerKey.includes("site")) return "website";
	if (lowerKey.includes("overview") || lowerKey.includes("project")) return "link";
	if (lowerKey.includes("slides")) return "slides";
	if (lowerKey.includes("poster")) return "poster";
	if (lowerKey.includes("dataset") || lowerKey.includes("huggingface")) return "dataset";
	return "link";
};

const getIconTitle = (key: string) => {
	const lowerKey = key.toLowerCase();
	if (lowerKey.includes("arxiv")) return "arXiv";
	if (lowerKey.includes("code") || lowerKey.includes("github")) return "Code";
	if (lowerKey.includes("pdf")) return "PDF";
	if (lowerKey.includes("paper") || lowerKey.includes("publication")) return "Paper";
	if (lowerKey.includes("video") || lowerKey.includes("demo")) return "Video";
	if (lowerKey.includes("website") || lowerKey.includes("site")) return "Website";
	if (lowerKey.includes("overview") || lowerKey.includes("project")) return "Project";
	if (lowerKey.includes("slides")) return "Slides";
	if (lowerKey.includes("poster")) return "Poster";
	if (lowerKey.includes("dataset") || lowerKey.includes("huggingface")) return "Dataset";
	return key;
};

const paperLink = Object.entries(research.data.links).find(([key]) =>
	key.toLowerCase().includes("paper") || key.toLowerCase().includes("publication")
)?.[1] as string || `/research/${research.id}`;

const categoryConfig: Record<string, { label: string; style: string }> = {
	preprint:   { label: "Preprint",   style: "bg-amber-100 text-amber-800 dark:bg-amber-400/15 dark:text-amber-300" },
	conference: { label: "Conference", style: "bg-sky-100 text-sky-800 dark:bg-sky-400/15 dark:text-sky-300" },
	journal:    { label: "Journal",    style: "bg-emerald-100 text-emerald-800 dark:bg-emerald-400/15 dark:text-emerald-300" },
	workshop:   { label: "Workshop",   style: "bg-violet-100 text-violet-800 dark:bg-violet-400/15 dark:text-violet-300" },
};

const category = research.data.category;
const catCfg = category ? categoryConfig[category] : null;
const year = new Date(research.data.publishDate).getFullYear();
const venue = research.data.venue;
const tldr = research.data.tldr;
---

<Element class="group flex flex-col gap-0 overflow-hidden rounded-xl border border-textColor/10 bg-bgColor shadow-sm transition-shadow hover:shadow-md dark:border-white/10">
	<div class="flex flex-col gap-4 p-5 sm:flex-row">

		<!-- Thumbnail -->
		<div class="shrink-0 self-center">
			<a
				href={paperLink}
				target={paperLink.startsWith("/") ? "_self" : "_blank"}
				rel={paperLink.startsWith("/") ? "" : "noopener noreferrer"}
				class="block overflow-hidden rounded-lg border border-textColor/10 dark:border-white/10"
			>
				<Image
					src={research.data.feature}
					alt={research.data.title}
					height={160}
					width={160}
					class="object-cover transition-transform duration-300 group-hover:scale-105"
				/>
			</a>
		</div>

		<!-- Body -->
		<div class="flex min-w-0 flex-1 flex-col gap-2">

			<!-- Line 1: Title -->
			<a
				href={paperLink}
				target={paperLink.startsWith("/") ? "_self" : "_blank"}
				rel={paperLink.startsWith("/") ? "" : "noopener noreferrer"}
			>
				<h2 class="text-sm font-bold leading-snug text-textColor transition-colors hover:text-accent dark:hover:text-accent">
					{research.data.title}
				</h2>
			</a>

			<!-- Line 2: Topic tags -->
			{research.data.tags && research.data.tags.length > 0 && (
				<div class="flex flex-wrap gap-1">
					{research.data.tags.map((tag: string) => (
						<span class="rounded-sm bg-textColor/8 px-1.5 py-0.5 text-xs text-textColor/60 dark:bg-white/8 dark:text-white/50">
							{tag}
						</span>
					))}
				</div>
			)}

			<!-- Line 3: Category · Venue · Year -->
			<div class="flex flex-wrap items-center gap-1.5">
				{catCfg && (
					<span class={`rounded-sm px-1.5 py-0.5 text-xs font-semibold uppercase tracking-wider ${catCfg.style}`}>
						{catCfg.label}
					</span>
				)}
				{venue && (
					<span class="font-mono text-xs font-semibold text-accent dark:text-accent">
						{venue}
					</span>
				)}
				<span class="font-mono text-xs text-textColor/40 dark:text-white/30">
					{year}
				</span>
			</div>

			<!-- Line 4: Authors -->
			<div class="flex flex-wrap gap-x-1 text-xs text-textColor/60 dark:text-white/50">
				{research.data.authors.map((author: string, idx: number) => (
					<span>
						<span class={idx === research.data.author_idx ? "font-semibold text-textColor underline decoration-accent decoration-2 underline-offset-2 dark:text-white" : ""}>{author}</span>{idx !== research.data.authors.length - 1 ? "," : ""}
					</span>
				))}
			</div>

			<!-- TL;DR -->
			{tldr && (
				<p class="border-l-2 border-accent/40 pl-2.5 text-xs leading-relaxed text-textColor/60 dark:border-accent/40 dark:text-white/50">
					<span class="font-semibold text-textColor/80 dark:text-white/70">TL;DR</span> — {tldr}
				</p>
			)}

			<!-- Line 5: Links -->
			<div class="flex flex-wrap gap-1.5 pt-0.5">
				{Object.entries(research.data.links).map(([key, value]) => {
					const iconType = getIcon(key);
					const iconTitle = getIconTitle(key);
					const url = value as string;
					return (
						<a
							href={url}
							target={url.startsWith("/") ? "_self" : "_blank"}
							rel={url.startsWith("/") ? "" : "noopener noreferrer"}
							class="flex items-center gap-1 rounded-sm border border-textColor/15 bg-textColor/5 px-2 py-1 text-xs font-medium text-textColor/70 transition-all hover:border-accent hover:bg-accent hover:text-white dark:border-white/15 dark:bg-white/5 dark:text-white/60 dark:hover:border-accent dark:hover:bg-accent dark:hover:text-white"
							title={iconTitle}
						>
							<Icon name={iconType} class="h-3.5 w-3.5" />
							<span>{iconTitle}</span>
						</a>
					);
				})}
			</div>

		</div>
	</div>
</Element>
