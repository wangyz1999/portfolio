---
import type { SiteMeta } from "@/data/siteMeta";
import BaseHead from "@/components/BaseHead";
import Header from "@/components/layout/Header";
import Footer from "@/components/layout/Footer";
import SkipLink from "@/components/SkipLink";
import { siteConfig } from "@/site-config";
import { Picture } from "astro:assets";
import profile_pic from "../assets/profile.webp";
import Icon from "../components/Icon.astro";
import { SOCIAL_LINKS } from "@/data/constants";

interface Props {
	meta: SiteMeta;
}

const {
	meta: { title, description = siteConfig.description, ogImage, articleDate },
} = Astro.props;
---

<html lang={siteConfig.lang}>
	<head>
		<BaseHead title={title} description={description} ogImage={ogImage} articleDate={articleDate} />
		<script define:vars={{ siteConfig }}>
			const root = document.documentElement;
			const colorThemeMetaTag = document.querySelector("meta[name='theme-color']");

			// get user preference of dark mode, 1st local storage, 2nd browser
			function getThemePreference() {
				if (typeof localStorage !== "undefined" && localStorage.getItem("theme")) {
					return localStorage.getItem("theme");
				}
				return "light";
			}

			const isDark = getThemePreference() === "dark";

			// watch document element class attribute and update user preference when it changes.
			const observer = new MutationObserver(() => {
				const rootIsDark = root.classList.contains("dark");
				// set the meta attribute
				colorThemeMetaTag.setAttribute(
					"content",
					siteConfig[rootIsDark ? "themeColorDark" : "themeColorLight"]
				);
				// store user preference
				if (typeof localStorage !== "undefined") {
					localStorage.setItem("theme", rootIsDark ? "dark" : "light");
				}
			});
			observer.observe(root, { attributeFilter: ["class"] });

			// initailse root class attribute
			root.classList.toggle("dark", isDark);
		</script>

		<!-- Google tag (gtag.js) -->
		<script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-Z93QE73T55"></script>
		<script is:inline>
		window.dataLayer = window.dataLayer || [];
		function gtag(){dataLayer.push(arguments);}
		gtag('js', new Date());
		gtag('config', 'G-Z93QE73T55');
		</script>


		<!-- Visitor tracking (invisible) -->
		<script is:inline type="text/javascript" id="mapmyvisitors" src="https://mapmyvisitors.com/map.js?cl=080808&w=a&t=n&d=1NaCE8A7TNCv-6PYXXfIIVHOovLZTWfmWlgG8roOsZ0&co=ffffff&ct=808080&cmo=3acc3a&cmn=ff5353"></script>
		<script is:inline>
			(function () {
				const remove = () => {
					document.querySelectorAll('[id*="mapmyvisitors"], [class*="mapmyvisitors"], a[href*="mapmyvisitors"], img[src*="mapmyvisitors"]').forEach(el => {
						const parent = el.closest('div, center, table') || el;
						parent.remove();
					});
				};
				remove();
				new MutationObserver(remove).observe(document.body, { childList: true, subtree: true });
			})();
		</script>
		<style>
			[id*="mapmyvisitors"], [class*="mapmyvisitors"], [src*="mapmyvisitors"],
			a[href*="mapmyvisitors"], img[src*="mapmyvisitors"],
			div:has(> a[href*="mapmyvisitors"]) { display: none !important; }
		</style>

		<!-- Matomo -->
		<!-- <script>
			var _paq = (window._paq = window._paq || []);
			/* tracker methods like "setCustomDimension" should be called before "trackPageView" */
			_paq.push(["trackPageView"]);
			_paq.push(["enableLinkTracking"]);
			(function () {
				var u = "https://yunzhew.matomo.cloud/";
				_paq.push(["setTrackerUrl", u + "matomo.php"]);
				_paq.push(["setSiteId", "1"]);
				var d = document,
					g = d.createElement("script"),
					s = d.getElementsByTagName("script")[0];
				g.async = true;
				g.src = "//cdn.matomo.cloud/yunzhew.matomo.cloud/matomo.js";
				s.parentNode.insertBefore(g, s);
			})();
		</script> -->
		<!-- End Matomo Code -->
	</head>
	<body>
		<SkipLink />
		<div class="mx-auto max-w-6xl px-4 sm:px-8">
			<Header />
			<div class="flex gap-10">
				<!-- Persistent sidebar -->
				<aside class="hidden lg:block lg:w-52 lg:flex-shrink-0">
					<div class="sticky top-20">
						<Picture
							class="w-full rounded-full mb-2 aspect-square object-cover"
							widths={[208, 416]}
							sizes="208px"
							loading="eager"
							width={288}
							height={288}
							src={profile_pic}
							alt="profile"
						/>
						<p class="mb-4 text-center text-lg font-bold text-textColor">Yunzhe Wang</p>
						<nav class="flex flex-row justify-center gap-1 mb-4">
							<a
								href={SOCIAL_LINKS.github}
								target="_blank"
								rel="noopener noreferrer"
								title="GitHub"
								class="p-2 rounded hover:bg-accent/10 transition-colors"
							>
								<Icon name="github" />
							</a>
							<a
								href={SOCIAL_LINKS.gscolar}
								target="_blank"
								rel="noopener noreferrer"
								title="Google Scholar"
								class="p-2 rounded hover:bg-accent/10 transition-colors"
							>
								<Icon name="scholar" />
							</a>
							<a
								href={`mailto:${SOCIAL_LINKS.email}`}
								title="Email"
								class="p-2 rounded hover:bg-accent/10 transition-colors"
							>
								<Icon name="email" />
							</a>
							<a
								href="/cv.pdf"
								target="_blank"
								title="CV"
								class="p-2 rounded hover:bg-accent/10 transition-colors"
							>
								<Icon name="cv-text" />
							</a>
						</nav>
						<div class="flex items-center justify-center gap-1 text-xs text-textColor/50">
							<Icon name="location" class="h-3.5 w-3.5 flex-shrink-0" />
							<span>Los Angeles, CA</span>
						</div>
					</div>
				</aside>

				<!-- Main content -->
				<main id="main" class="flex-1 min-w-0">
					<!-- Mobile: centered profile block -->
					<div class="flex flex-col items-center mb-8 lg:hidden">
						<Picture
							class="h-28 w-28 rounded-full object-cover mb-2"
							widths={[112, 224]}
							sizes="112px"
							loading="eager"
							width={224}
							height={224}
							src={profile_pic}
							alt="profile"
						/>
						<p class="mb-2 text-base font-bold text-textColor">Yunzhe Wang</p>
						<nav class="flex flex-row gap-1 mb-2">
							<a href={SOCIAL_LINKS.github} target="_blank" rel="noopener noreferrer" title="GitHub" class="p-2 rounded hover:bg-accent/10 transition-colors">
								<Icon name="github" />
							</a>
							<a href={SOCIAL_LINKS.gscolar} target="_blank" rel="noopener noreferrer" title="Google Scholar" class="p-2 rounded hover:bg-accent/10 transition-colors">
								<Icon name="scholar" />
							</a>
							<a href={`mailto:${SOCIAL_LINKS.email}`} title="Email" class="p-2 rounded hover:bg-accent/10 transition-colors">
								<Icon name="email" />
							</a>
							<a href="/cv.pdf" target="_blank" title="CV" class="p-2 rounded hover:bg-accent/10 transition-colors">
								<Icon name="cv-text" />
							</a>
						</nav>
						<div class="flex items-center gap-1 text-xs text-textColor/50">
							<Icon name="location" class="h-3.5 w-3.5 flex-shrink-0" />
							<span>Los Angeles, CA</span>
						</div>
					</div>
					<slot />
				</main>
			</div>
			<Footer />
		</div>
	</body>
</html>
